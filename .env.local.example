# ─── Formulário de contato ───────────────────────────────────────────────────
#
# Copie este arquivo para .env.local e preencha com as suas credenciais SMTP.
# No Railway, adicione as variáveis diretamente nas configurações de ambiente.
#
# Exemplos de provedores SMTP:
#
#  Gmail (requer "Senha de app" — ative a verificação em 2 etapas antes):
#    SMTP_HOST=smtp.gmail.com
#    SMTP_PORT=587
#    SMTP_SECURE=false
#    SMTP_USER=seuemail@gmail.com
#    SMTP_PASS=xxxx xxxx xxxx xxxx   ← senha de app (não a senha normal)
#
#  Zoho Mail:
#    SMTP_HOST=smtp.zoho.com
#    SMTP_PORT=587
#    SMTP_SECURE=false
#
#  Office 365 / Outlook:
#    SMTP_HOST=smtp.office365.com
#    SMTP_PORT=587
#    SMTP_SECURE=false
#
# ─────────────────────────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seuemail@dominio.com.br
SMTP_PASS=sua_senha_de_app

# E-mail que receberá as mensagens dos formulários
CONTACT_EMAIL=contato@isf.com.br

# Remetente (opcional — se omitido, usa SMTP_USER)
# SMTP_FROM=site@isf.com.br
