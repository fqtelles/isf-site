# ─── Formulário de contato (Resend) ──────────────────────────────────────────
#
# 1. Crie uma conta gratuita em resend.com
# 2. Gere uma API Key em resend.com/api-keys
# 3. Adicione as variáveis abaixo no Railway (ou no .env.local para rodar local)
#
# ─────────────────────────────────────────────────────────────────────────────

# Chave de API do Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# E-mail que receberá as mensagens dos formulários
CONTACT_EMAIL=contato@isf.com.br

# Remetente — enquanto não verificar um domínio próprio, use o endereço padrão do Resend:
# RESEND_FROM=ISF Site <onboarding@resend.dev>
#
# Após verificar seu domínio (ex: isf.com.br) no Resend, use:
# RESEND_FROM=ISF Site <contato@isf.com.br>
